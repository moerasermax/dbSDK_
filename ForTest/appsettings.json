{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionSettings": {
    "Mongo": {
      "Uri": "MONGODB_ENDPOINT_URL",
      "User": "USER_NAME",
      "Password": "USER_PASSWORD"
    },
    "Elastic": {
      "EndPoint": "ELASTIC_ENDPOINT",
      "ApiKey": "USER_APIKEY"
    },
    "Redis": {
      "EndPoint": "REDIS_ENDPOINT",
      "Port": 0,
      "User": "USER_NAME",
      "Password": "USER_PASSWORD"
    }
  }
}
